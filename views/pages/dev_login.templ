package pages

import (
	"github.com/mbarek-hani/FluxHUB/views/layouts"
	"github.com/mbarek-hani/FluxHUB/views/components"
)

templ DevLogin(errorMsg string) {
	@layouts.Base("Login") {
		<div class="max-w-md mx-auto mt-16 bg-white dark:bg-gray-800 rounded-xl shadow-md overflow-hidden border border-gray-100 dark:border-gray-700">
			<div class="p-8">
				<div class="flex flex-col items-center mb-8">
					<img src="/static/icons/favicon.svg" alt="FluxHUB Logo" class="w-16 h-16 mb-4"/>
					<h1 class="text-2xl font-bold text-gray-900 dark:text-white">Sign in to FluxHUB</h1>
					<p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">Welcome back to the marketplace</p>
				</div>

				if errorMsg == "invalid" {
					@components.Alert("invalid github account.", "error")
				} else if errorMsg == "server" {
					@components.Alert("An internal server error occurred. Please try again.", "error")
				} else if errorMsg == "admin_only" {
					@components.Alert("Developers must sign in using GitHub.", "error")
				} else if errorMsg == "github_failed" {
					@components.Alert("Failed to authenticate with GitHub. Please try again.", "error")
				} else if errorMsg == "account_blocked" {
					@components.Alert("Your account has been blocked by the Administrator.", "error")
				}

				<div class="mt-4">
					<a href="/auth/github" class="w-full flex justify-center items-center gap-2 py-2.5 px-4 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm bg-white dark:bg-gray-700 text-sm font-medium text-gray-700 dark:text-white hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-800 transition-colors">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
						</svg>
						Sign in with GitHub
					</a>
				</div>
			</div>
		</div>
	}
}
